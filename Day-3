//Q11- WAP TO FIND LCM OF A GIVEN NUMBER-
#include<iostream>
using namespace std;
int main(){
    int a,b;
    cout<<"ENTER THE VALUE OF A = ";
    cin>>a;
    cout<<"ENTER THE VALUE OF B = ";
    cin>>b;
    int max = (a > b) ? a : b;
    int lcm = max;
    while(true){
        if(lcm % a == 0 && lcm % b == 0){
            break;
        }
        lcm += max;
    }
    cout<<"LCM OF "<<a<<" AND "<<b<<" IS = "<<lcm;
    return 0;
}       







//Q12- WAP TO FIND GCD OF A NUMBER.
#include<iostream>
using namespace std;
int main(){                 
    int a,b;
    cout<<"ENTER THE VALUE OF A = ";
    cin>>a;
    cout<<"ENTER THE VALUE OF B = ";
    cin>>b;
    while(b!=0){
        int temp = b;
        b = a % b;
        a = temp;
    }
    cout<<"GCD IS = "<<a;
    return 0;
}

