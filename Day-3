//Q9- WAP TO CHECK IF A NUMBER IS PRIME OR NOT-
#include<iostream>
#include<cmath>
using namespace std;

bool isPrime(int n){
    if(n==1){
        return false;
    }
    for(int i = 2; i<=sqrt(n) ; i++){
       if(n % i == 0){
        return false;
       }   
       return true;                      //non-prime
    }
return 0;
}

int main(){
    cout << isPrime(6) << endl;
    return 0;
}







//Q10- WAP TO PRINT PRIME NUMBERS IN A RANGE.
#include<iostream>
#include<cmath>
using namespace std;
int main(){
    int n;
    cout<<"ENTER THE VALUE OF N = ";
    cin>>n;
    for(int i=2; i<=n; i++){
        bool isPrime = true;
        for(int j=2; j<=sqrt(i); j++){
            if(i % j == 0){
                isPrime = false;
                break;
            }
        }
        if(isPrime){
            cout<<i<<" ";
        }
    }
    return 0;
}







