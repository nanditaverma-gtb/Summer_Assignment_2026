//WAP TO CONVERT DECIMAL TO BINARY.
#include<iostream>
using namespace std;
int main()
{
    int n;
    cout<<"Enter a decimal number: ";   
    cin>>n;
    int binary[32], i = 0;
    while(n > 0)
    {
        binary[i] = n % 2;
        n = n / 2;
        i++;
    }
    cout<<"Binary representation: ";    
    for(int j = i - 1; j >= 0; j--) 
    {
        cout<<binary[j];
    }
    cout<<endl;
    return 0;
}







//WAP TO CONVERT BINARY TO DECIMAL.
#include<iostream>
using namespace std;
int main()
{
    int n, decimal = 0, base = 1, remainder;
    cout<<"Enter a binary number: ";
    cin>>n;
    while(n > 0)
    {
        remainder = n % 10;
        decimal = decimal + remainder * base;
        base = base * 2;
        n = n / 10;
    }
    cout<<"Decimal representation: "<<decimal<<endl;
    return 0;
}







//WAP TO COUNT SET BITS IN A NUMBER.
#include<iostream>
using namespace std;
int main()
{
    int n, count = 0;
    cout<<"Enter a number: ";   
    cin>>n;
    while(n > 0)
    {
        if(n & 1) // Check if the least significant bit is set
        {
            count++; // Increment count if the bit is set
        }       
          n = n >> 1; // Right shift the number to check the next bit
    }
    cout<<"Number of set bits: "<<count<<endl;
    return 0;
}







//WAP TO FIND X^n WITHOUT USING POW FUNCTION.
#include<iostream>
using namespace std;
int main()
{
    int x, n;       
    cout<<"Enter the value of x: ";
    cin>>x;
    cout<<"Enter the value of n: ";
    cin>>n;
    int result = 1;
    for(int i = 0; i < n; i++)
    {
        result = result * x;
    }
    cout<<x<<" raised to the power "<<n<<" is: "<<result<<endl;
    return 0;
}
