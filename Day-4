//Q13- wap to generate fibonacci deries.
#include<iostream>
using namespace std;
int main(){
    int n;
    cout<<"ENTER THE VALUE OF N = ";
    cin>>n;
    int a=0, b=1, c;
    cout<<a<<" "<<b<<" ";
    for(int i=2; i<n; i++){
        c = a + b;
        cout<<c<<" ";
        a = b;
        b = c;
    }
    return 0;
}







//Q14- WAP TO FIND NTH TERM OF FIBONACCI SERIES-
#include<iostream>
using namespace std;
int main(){
    int n;                                      
    cout<<"ENTER THE VALUE OF N = ";
    cin>>n;
    int a=0, b=1, c;
    if(n==1){
        cout<<a;
    }
    else if(n==2){
        cout<<b;
    }
    else{
        for(int i=2; i<=n; i++){
            c = a + b;
            a = b;
            b = c;
        }
        cout<<c;
    }
    return 0;
}







//Q15- WAP TO CHECK IF A NUMBER IS ARMSTRONG OR NOT-
#include<iostream>
#include<cmath>
using namespace std;
int main(){
    int n, originalNum, remainder, result = 0, digits = 0;
    cout<<"ENTER THE VALUE OF N = ";
    cin>>n;
    originalNum = n;
    while (originalNum != 0) {
        originalNum /= 10;
        digits++;
    }
    originalNum = n;
    while (originalNum != 0) {
        remainder = originalNum % 10;       
        result += pow(remainder, digits);
        originalNum /= 10;
    }
    if (result == n) {
        cout << n << " is an Armstrong number." << endl;
    } else {
        cout << n << " is not an Armstrong number." << endl;
    }
    return 0;
}







//Q16- WAP TO PRINT ARMSTRONG NUMBERS IN A RANGE-
#include<iostream>
#include<cmath>
using namespace std;
int main() {
    int low, high;
    cout << "ENTER THE LOWER VALUE OF RANGE = ";
    cin >> low;
    cout << "ENTER THE UPPER VALUE OF RANGE = ";
    cin >> high;
    cout << "ARMSTRONG NUMBERS BETWEEN " << low << " AND " << high << " ARE: " << endl;
    for (int num = low; num <= high; num++) {
        int originalNum = num, remainder, result = 0, digits = 0;
        while (originalNum != 0) {
            originalNum /= 10; 
            digits++;
        }
        originalNum = num;     
        while (originalNum != 0) {
            remainder = originalNum % 10;       
            result += pow(remainder, digits);
            originalNum /= 10;
        }   
    if (result == num) {
            cout << num << " ";
        }
    }
    cout << endl;           
    return 0;   
}   
