//Q8- WAP TO CHECK IF A NUMBER IS PALINDROME OR NOT-
#include<iostream>
using namespace std;

int reverse (int n){
    int res = 0;
    while (n > 0){
        int lastDig = n % 10;
        res = res * 10 + lastDig;
        n = n / 10;
    }
return res;
}
    
bool isPalin(int num){
    int revNum = reverse(567765);
    return num == revNum;
}

int main(){
    int n = 567765;
    if(isPalin(n)){
        cout << "PALINDROME";
    } else {
        cout << "NOT PALINDROME";
    }
    cout << endl;
    return 0;
}
