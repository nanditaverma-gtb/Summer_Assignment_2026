//QUES-1-CALCULATE THE SUM OF FIRST N NATURAL NUMBERS.
#include <iostream>
using namespace std;

int main(){
    int n;
    cout<<"Enter the nth term: ";
    cin>> n;
    cout<<"The sum of first n natural number is: "<<(n*(n+1)/2) <<endl;
    return 0;
}



//QUES-2-WRITE A PROGRAM TO PRINT THE MULTIPLICATION TABLE OF A GIVEN NUMBER.
#include <iostream>
using namespace std;
int main(){
    int n;
    cout<<"Enter the number to find its table:";
    cin>>n;
    cout<<"The multiplication table of n is: "<<endl;
    for(int i=1; i<=10; i++){
        cout<<n<<" * "<<i<<" = "<<n*i<<endl;
    }
    return 0;
}



