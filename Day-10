//Q40- WAP TO PRINT CHARACTER PYRAMID.
#include<iostream>
using namespace std;
int main(){
    int n;  
    cout<<"ENTER THE VALUE OF N- ";
    cin>>n;
    for(int i=1; i<=n; i++){
        for(int j=1; j<=n-i; j++){
            cout<<" ";
        }
        for(int k=1; k<=(2*i-1); k++){
            cout<<(char)(64+i);
        }       
        cout<<endl;
    }
    return 0;
}
